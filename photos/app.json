{
  "expo": {
    "name": "Debajyoti Photos",
    "slug": "debajyoti-photos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.debajyoti.photos",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Debajyoti Photos imports selected photos and videos for backup.",
        "NSCameraUsageDescription": "Debajyoti Photos can capture photos and videos for backup."
      }
    },
    "android": {
      "package": "com.debajyoti.photos",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101820"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
